    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.170.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.24.0",
    "supabase": "2.62.10",
    "tailwindcss": "4",
    "typescript": "^5.9.3",
