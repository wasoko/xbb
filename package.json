    "dexie": "^4.2.1",
    "dexie-react-hooks": "^4.2.0",
    "diff-match-patch": "^1.0.5",
    "es-toolkit": "^1.43.0",
    "framer-motion": "^12.23.26",
    "lodash": "^4.17.21",
    "lucide-react": "^0.548.0",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-to-string": "^4.0.0",
    "pako": "^2.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.11.0",
    "remark": "^15.0.1",
    "three": "^0.170.0",
