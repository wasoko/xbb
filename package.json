{
  "name": "tagweb",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf build.out",
    "build": "vite build --base ./",
    "dev": "vite --base ./ --host 0.0.0.0  -- --watch ### https://share.google/aimode/i0TLb0scRlD2oWEp1",
	    "test": "bun test",
    "tsgo:tw": "concurrently --names \"tsgo,tw\" --prefix-colors \"cyan,green\" \"tsgo -p tsconfig.build.json --watch --preserveWatchOutput\" \"tailwindcss -i ./src/app.css -o ./dist/app.css --watch\" ",
    "preview": "vite preview",
    "check": "npx biome check --write --error-on-warnings . && tsgo --noEmit  ### && cd packages/web-ui && npm run check",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.49.10",
